<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:FaunaConnect2.App.ViewModels"
             x:Class="FaunaConnect2.App.NewRegistrationPage"
             x:DataType="viewmodels:RegistrationViewModel"
             Title="New Sighting">
    
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Label Text="What did you see?" FontSize="22" FontAttributes="Bold" TextColor="#2B5B2B"/>
            
            <Picker Title="Select animal species" 
                    ItemsSource="{Binding SpeciesList}"
                    SelectedItem="{Binding SelectedSpecies}"
                    HeightRequest="50"/>
            
            <Button Text="📷 Take Photo" 
                    Command="{Binding TakePhotoCommand}" 
                    BackgroundColor="Gray" 
                    TextColor="White" 
                    CornerRadius="10"/>
            
            <Image Source="{Binding CapturedImageSource}" 
                   HeightRequest="200" 
                   Aspect="AspectFill" 
                   IsVisible="{Binding IsImageVisible}"/>

            <BoxView HeightRequest="1" BackgroundColor="#EEEEEE"/>
            
            <Label Text="{Binding LocationText}" FontSize="14" HorizontalOptions="Center"/>
            
            <Button Text="📍 Adjust Location on Map" 
                    Command="{Binding PickLocationCommand}" 
                    BackgroundColor="Transparent" 
                    TextColor="#2B5B2B" 
                    BorderColor="#2B5B2B" 
                    BorderWidth="1" 
                    CornerRadius="10"/>

            <Button Text="Save" 
                    Command="{Binding SaveCommand}" 
                    BackgroundColor="#2B5B2B" 
                    TextColor="White" 
                    HeightRequest="50" 
                    CornerRadius="25"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>