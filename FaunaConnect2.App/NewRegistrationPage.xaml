<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FaunaConnect2.App.NewRegistrationPage"
             Title="Nieuwe Waarneming">
    
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Label Text="Wat heb je gezien?" FontSize="22" FontAttributes="Bold" TextColor="#2B5B2B"/>
            
            <Picker x:Name="SpeciesPicker" Title="Selecteer diersoort" HeightRequest="50"/>
            
            <Button Text="📷 Foto maken" Clicked="OnTakePhotoClicked" BackgroundColor="Gray" TextColor="White" CornerRadius="10"/>
            <Image x:Name="CapturedImage" HeightRequest="200" Aspect="AspectFill" IsVisible="False"/>

            <BoxView HeightRequest="1" BackgroundColor="#EEEEEE"/>
            
            <Label x:Name="LocationLabel" Text="Locatie: nog niet bepaald" FontSize="14" HorizontalOptions="Center"/>
            <Button Text="📍 Locatie aanpassen op kaart" Clicked="OnPickLocationClicked" BackgroundColor="Transparent" TextColor="#2B5B2B" BorderColor="#2B5B2B" BorderWidth="1" CornerRadius="10"/>

            <Button Text="Opslaan" Clicked="OnSaveClicked" BackgroundColor="#2B5B2B" TextColor="White" HeightRequest="50" CornerRadius="25"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>