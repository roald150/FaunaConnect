<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:FaunaConnect2.App.ViewModels"
             xmlns:models="clr-namespace:FaunaConnect2.App.Models"
             x:Class="FaunaConnect2.App.AdminPage"
             x:DataType="viewmodels:AdminViewModel"
             Title="Admin">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label Text="Admin Panel" FontSize="22" FontAttributes="Bold"/>
            
            <Label Text="Add new animal species:" FontSize="16"/>
            <HorizontalStackLayout Spacing="10">
                <Entry Text="{Binding NewSpeciesName}" Placeholder="Name..." WidthRequest="250"/>
                <Button Text="Add" Command="{Binding AddSpeciesCommand}" BackgroundColor="#2B5B2B" TextColor="White"/>
            </HorizontalStackLayout>

            <Label Text="Current animal species:" FontSize="16" Margin="0,10,0,0"/>
            <CollectionView ItemsSource="{Binding SpeciesList}" HeightRequest="150">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="viewmodels:AdminViewModel+SpeciesDto">
                        <Label Text="{Binding Name}" Padding="5" FontSize="16"/>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <BoxView HeightRequest="1" Color="Gray" Margin="0,10"/>

            <Label Text="Manage Users" FontSize="20" FontAttributes="Bold"/>
            
            <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto" ColumnSpacing="5">
                <Entry Text="{Binding NewUserName}" Placeholder="Name" Grid.Column="0"/>
                <Entry Text="{Binding NewUserEmail}" Placeholder="Email" Grid.Column="1"/>
                <Picker SelectedItem="{Binding SelectedUserRole}" Title="Role" ItemsSource="{Binding Roles}" Grid.Column="2" />
            </Grid>
            <Button Text="New User" Command="{Binding AddUserCommand}" BackgroundColor="#2B5B2B" TextColor="White"/>

            <CollectionView ItemsSource="{Binding UsersList}" Margin="0,10,0,0">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:User">
                        <Border Margin="0,5" Padding="10">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="5"/>
                            </Border.StrokeShape>
                            <HorizontalStackLayout Spacing="10">
                                <VerticalStackLayout WidthRequest="200">
                                    <Label Text="{Binding Name}" FontAttributes="Bold"/>
                                    <Label Text="{Binding Email}" FontSize="12"/>
                                    <Label Text="{Binding Role}" FontSize="12" TextColor="Gray"/>
                                </VerticalStackLayout>
                                <!-- Edit logic is complex, for now we just have delete -->
                                <Button Text="X" Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:AdminViewModel}}, Path=DeleteUserCommand}" CommandParameter="{Binding .}" HeightRequest="40" BackgroundColor="Red" TextColor="White"/>
                            </HorizontalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
