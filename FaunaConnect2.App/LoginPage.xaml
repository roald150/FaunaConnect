<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:FaunaConnect2.App.ViewModels"
             x:Class="FaunaConnect2.App.LoginPage"
             x:DataType="viewmodels:LoginViewModel"
             Title="FaunaConnect2 - Login">

    <VerticalStackLayout Padding="30" Spacing="15" VerticalOptions="Center">
        <Label Text="FaunaConnect2" FontSize="32" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{StaticResource Primary}"/>
        <Label Text="Log in to continue" FontSize="16" HorizontalOptions="Center" TextColor="Gray"/>

        <Entry Text="{Binding Email}" Placeholder="Email address" Keyboard="Email" />
        <Entry Text="{Binding Password}" Placeholder="Password" IsPassword="True" />

        <Button Text="Login" Command="{Binding LoginCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" Margin="0,10,0,0"/>
        
        <Button Text="No account? Register here" 
                Command="{Binding GoToRegisterCommand}" 
                BackgroundColor="Transparent" 
                TextColor="{StaticResource Primary}"/>
        
        <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center"/>
    </VerticalStackLayout>
</ContentPage>