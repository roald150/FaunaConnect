<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FaunaConnect2.App.LoginPage"
             Title="FaunaConnect2 - Login">

    <VerticalStackLayout Padding="30" Spacing="15" VerticalOptions="Center">
        <Label Text="FaunaConnect2" FontSize="32" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{StaticResource Primary}"/>
        <Label Text="Log in om door te gaan" FontSize="16" HorizontalOptions="Center" TextColor="Gray"/>

        <Entry x:Name="EmailEntry" Placeholder="E-mailadres" Keyboard="Email" />
        <Entry x:Name="PasswordEntry" Placeholder="Wachtwoord" IsPassword="True" />

        <Button Text="Inloggen" Clicked="OnLoginClicked" Margin="0,10,0,0"/>
        
        <Button Text="Nog geen account? Registreer hier" 
                Clicked="OnGoToRegisterClicked" 
                BackgroundColor="Transparent" 
                TextColor="{StaticResource Primary}"/>
    </VerticalStackLayout>
</ContentPage>