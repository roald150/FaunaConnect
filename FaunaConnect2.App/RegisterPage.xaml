<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:FaunaConnect2.App.ViewModels"
             x:Class="FaunaConnect2.App.RegisterPage"
             x:DataType="viewmodels:RegisterViewModel"
             Title="Register">

    <VerticalStackLayout Padding="30" Spacing="15" VerticalOptions="Center">
        <Label Text="Create an account" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center"/>

        <Entry Text="{Binding Name}" Placeholder="Full name" />
        <Entry Text="{Binding Email}" Placeholder="Email address" Keyboard="Email" />
        <Entry Text="{Binding Password}" Placeholder="Password" IsPassword="True" />
        
        <Label Text="I am a:" FontSize="14" TextColor="Gray"/>
        <Picker ItemsSource="{Binding Roles}"
                SelectedItem="{Binding SelectedRole}" />

        <Button Text="Register" Command="{Binding RegisterCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" Margin="0,10,0,0"/>
        
        <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center"/>
    </VerticalStackLayout>
</ContentPage>