<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FaunaConnect2.App.ChatPage"
             Title="Chat">
    <Grid RowDefinitions="*,Auto" Padding="10">
        
        <CollectionView x:Name="MessagesListView" Grid.Row="0">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <VerticalStackLayout Padding="5" Margin="0,2">
                        <Border Padding="10" 
                                HorizontalOptions="{Binding Alignment}"
                                BackgroundColor="{Binding BgColor}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10"/>
                            </Border.StrokeShape>
                            <VerticalStackLayout>
                                <Label Text="{Binding SenderName}" FontSize="10" FontAttributes="Bold" TextColor="Gray"/>
                                <Label Text="{Binding Content}" TextColor="Black"/>
                                <Label Text="{Binding Timestamp, StringFormat='{0:HH:mm}'}" FontSize="8" TextColor="DimGray" HorizontalOptions="End"/>
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <HorizontalStackLayout Grid.Row="1" Spacing="10" Padding="5">
            <Entry x:Name="MessageEntry" Placeholder="Typ een bericht..." WidthRequest="300"/>
            <Button Text="Verstuur" Clicked="OnSendClicked" BackgroundColor="#2B5B2B" TextColor="White"/>
        </HorizontalStackLayout>
    </Grid>
</ContentPage>