<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:FaunaConnect2.App.ViewModels"
             xmlns:models="clr-namespace:FaunaConnect2.App.Models"
             x:Class="FaunaConnect2.App.DamageReportPage"
             x:DataType="viewmodels:DamageReportViewModel"
             Title="Report Wildlife Damage">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <Label Text="Report Wildlife Damage" FontSize="22" FontAttributes="Bold" TextColor="#B22222"/>
            
            <Editor Text="{Binding Description}" Placeholder="Describe the damage..." HeightRequest="100"/>
            
            <Button Text="📷 Damage Photo" Command="{Binding TakePhotoCommand}" BackgroundColor="Gray" TextColor="White"/>
            <Image Source="{Binding CapturedImageSource}" HeightRequest="200" Aspect="AspectFill" IsVisible="{Binding IsImageVisible}"/>

            <BoxView HeightRequest="1" BackgroundColor="#EEEEEE"/>
            <Label Text="{Binding LocationText}" FontSize="14" HorizontalOptions="Center"/>
            <Button Text="📍 Adjust Location on Map" Command="{Binding PickLocationCommand}" BackgroundColor="Transparent" TextColor="#B22222" BorderColor="#B22222" BorderWidth="1" CornerRadius="10"/>

            <Button Text="Send Report" Command="{Binding SendCommand}" BackgroundColor="#B22222" TextColor="White" HeightRequest="50" CornerRadius="25"/>

            <BoxView HeightRequest="1" Color="Gray" Margin="0,10"/>
            <Label Text="Existing Reports" FontSize="20" FontAttributes="Bold" TextColor="#B22222"/>
            
            <CollectionView ItemsSource="{Binding Reports}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:DamageReportDto">
                        <Border Margin="0,5" Padding="10" Stroke="#B22222">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="5"/>
                            </Border.StrokeShape>
                            <VerticalStackLayout>
                                <Label Text="{Binding Description}" FontAttributes="Bold"/>
                                <Label Text="{Binding Timestamp, StringFormat='{0:dd-MM-yyyy HH:mm}'}" FontSize="12" TextColor="Gray"/>
                                <Label Text="{Binding User.Name, StringFormat='Reported by: {0}'}" FontSize="12"/>
                                <Label Text="{Binding Latitude, StringFormat='Lat: {0:F4}, Lng: {1:F4}'}" FontSize="10" TextColor="Gray"/>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>