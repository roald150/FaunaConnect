<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="http://schemas.microsoft.com/dotnet/2021/maui/maps"
             xmlns:viewmodels="clr-namespace:FaunaConnect2.App.ViewModels"
             x:Class="FaunaConnect2.App.MapPage"
             x:DataType="viewmodels:MapViewModel"
             Title="Hunting Ground Map"
             BackgroundColor="White">

    <Grid RowDefinitions="Auto, *">
        <SearchBar x:Name="MapSearchBar" 
                   Placeholder="Search by address or location..." 
                   Text="{Binding SearchText}"
                   SearchCommand="{Binding SearchCommand}"
                   Grid.Row="0"
                   Margin="10,10,60,10"
                   BackgroundColor="White"/>

        <Button Text="🔄" 
                Command="{Binding RefreshCommand}"
                Grid.Row="0"
                HorizontalOptions="End"
                Margin="10"
                WidthRequest="44"
                HeightRequest="44"
                Padding="0"
                BackgroundColor="#2B5B2B"
                TextColor="White"
                CornerRadius="22"/>
        
        <WebView x:Name="MapWebView" 
                 Source="map.html"
                 Navigating="OnWebViewNavigating"
                 Grid.Row="1"/>

        <ActivityIndicator IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"
                           Color="#2B5B2B"
                           WidthRequest="50"
                           HeightRequest="50"
                           Grid.Row="1"/>

        <Button x:Name="ShowPanelButton"
                Text="📋 Options"
                Clicked="OnShowPanelClicked"
                IsVisible="False"
                Grid.Row="1"
                VerticalOptions="End"
                HorizontalOptions="End"
                Margin="20,40"
                Padding="15,0"
                HeightRequest="44"
                CornerRadius="22"
                BackgroundColor="#2B5B2B"
                TextColor="White">
            <Button.Shadow>
                <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.3"/>
            </Button.Shadow>
        </Button>

        <Border x:Name="InfoPanel"
                Grid.Row="1"
                VerticalOptions="End" 
                HorizontalOptions="Fill" 
                Margin="20,30" 
                Padding="20" 
                BackgroundColor="White" 
                Stroke="#E0E0E0"
                StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="8"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.1"/>
            </Border.Shadow>
            
            <VerticalStackLayout Spacing="10">
                <Grid ColumnDefinitions="*, Auto, Auto">
                    <Label Text="Selected Parcel" FontAttributes="Bold" FontSize="18" TextColor="#333333" Grid.Column="0"/>
                    
                    <Button Text="❌ Clear" 
                            Command="{Binding DeselectCommand}" 
                            BackgroundColor="Transparent" 
                            TextColor="#666" 
                            FontSize="12"
                            Padding="5"
                            HeightRequest="30"
                            Grid.Column="1"
                            Margin="0,0,10,0"/>

                    <Button Text="✖️ Close" 
                            Clicked="OnHidePanelClicked" 
                            BackgroundColor="#F5F5F5" 
                            TextColor="#333" 
                            FontSize="12"
                            Padding="10,0"
                            HeightRequest="30"
                            CornerRadius="15"
                            Grid.Column="2"/>
                </Grid>
                
                <Label Text="{Binding ParcelIdText}" TextColor="#666666" FontSize="14"/>
                <Label Text="{Binding ParcelSizeText}" TextColor="#2B5B2B" FontSize="14" FontAttributes="Bold"/>
                
                <BoxView HeightRequest="1" BackgroundColor="#EEEEEE" Margin="0,5"/>
                
                <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                    <Label Text="Show Safety Circle" VerticalOptions="Center" FontSize="14"/>
                    <Switch IsToggled="{Binding IsCircleVisible}" Toggled="OnCircleToggleToggled"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                    <Label Text="Show Wildlife Damage" VerticalOptions="Center" FontSize="14"/>
                    <Switch IsToggled="{Binding IsDamageVisible}" Toggled="OnDamageToggleToggled"/>
                </HorizontalStackLayout>

                <Button Text="⚠️ Report Wildlife Damage Here" 
                        Command="{Binding ReportDamageCommand}"
                        BackgroundColor="#B22222"
                        TextColor="White"
                        CornerRadius="4"
                        HeightRequest="44"
                        FontSize="16"
                        Margin="0,5,0,0"/>

                <Button Text="Save as Hunting Ground" 
                        Command="{Binding SaveHuntingGroundCommand}"
                        IsVisible="{Binding IsSaveGroundVisible}"
                        BackgroundColor="#2B5B2B"
                        TextColor="White"
                        CornerRadius="4"
                        HeightRequest="44"
                        FontSize="16"/>

                <Label Text="Radius: 300m safety circle" FontSize="11" TextColor="#D32F2F" HorizontalOptions="Start"/>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>