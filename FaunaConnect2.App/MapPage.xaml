<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="http://schemas.microsoft.com/dotnet/2021/maui/maps"
             x:Class="FaunaConnect2.App.MapPage"
             Title="Jachtveld Kaart"
             BackgroundColor="White">

    <Grid>
        <maps:Map x:Name="JachtMap" 
                  IsShowingUser="True" 
                  MapClicked="OnMapClicked"/>

        <Frame VerticalOptions="End" 
               HorizontalOptions="Fill" 
               Margin="20,40" 
               Padding="15" 
               BackgroundColor="#F0F8FF" 
               BorderColor="DarkSlateGray"
               CornerRadius="12" 
               HasShadow="True">
            
            <VerticalStackLayout Spacing="8">
                <HorizontalStackLayout Spacing="10">
                    <Label Text="🗺️" FontSize="20"/>
                    <Label Text="Geselecteerd Perceel:" FontAttributes="Bold" FontSize="16" TextColor="Black"/>
                </HorizontalStackLayout>
                
                <Label x:Name="ParcelIdLabel" Text="Klik op de kaart om een perceel in te laden..." TextColor="DimGray"/>
                <Label x:Name="ParcelSizeLabel" Text="Grootte: -- m²" TextColor="DimGray" FontAttributes="Bold"/>
                
                <BoxView HeightRequest="1" BackgroundColor="LightGray" Margin="0,5"/>
                
                <Label Text="🛡️ Veiligheidsradius: 300m schietcirkel actief" FontSize="12" TextColor="DarkGreen" FontAttributes="Italic"/>
            </VerticalStackLayout>
        </Frame>
    </Grid>
</ContentPage>