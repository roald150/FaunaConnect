<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="http://schemas.microsoft.com/dotnet/2021/maui/maps"
             x:Class="FaunaConnect2.App.MapPage"
             Title="Jachtveld Kaart"
             BackgroundColor="White">

    <Grid RowDefinitions="Auto, *">
        <SearchBar x:Name="MapSearchBar" 
                   Placeholder="Zoek op adres of locatie..." 
                   SearchButtonPressed="OnSearchButtonPressed"
                   Grid.Row="0"
                   Margin="10,10,60,10"
                   BackgroundColor="White"/>

        <Button Text="🔄" 
                Clicked="OnRefreshClicked"
                Grid.Row="0"
                HorizontalOptions="End"
                Margin="10"
                WidthRequest="44"
                HeightRequest="44"
                Padding="0"
                BackgroundColor="#2B5B2B"
                TextColor="White"
                CornerRadius="22"/>
        
        <WebView x:Name="MapWebView" 
                 Source="map.html"
                 Navigating="OnWebViewNavigating"
                 Grid.Row="1"/>

        <ActivityIndicator x:Name="MapLoadingIndicator"
                           IsRunning="False"
                           IsVisible="False"
                           VerticalOptions="Center"
                           HorizontalOptions="Center"
                           Color="#2B5B2B"
                           WidthRequest="50"
                           HeightRequest="50"
                           Grid.Row="1"/>

        <Button x:Name="ShowPanelButton"
                Text="📋 Opties"
                Clicked="OnShowPanelClicked"
                IsVisible="False"
                Grid.Row="1"
                VerticalOptions="End"
                HorizontalOptions="End"
                Margin="20,40"
                Padding="15,0"
                HeightRequest="44"
                CornerRadius="22"
                BackgroundColor="#2B5B2B"
                TextColor="White">
            <Button.Shadow>
                <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.3"/>
            </Button.Shadow>
        </Button>

        <Border x:Name="InfoPanel"
                Grid.Row="1"
                VerticalOptions="End" 
                HorizontalOptions="Fill" 
                Margin="20,30" 
                Padding="20" 
                BackgroundColor="White" 
                Stroke="#E0E0E0"
                StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="8"/>
            </Border.StrokeShape>
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.1"/>
            </Border.Shadow>
            
            <VerticalStackLayout Spacing="10">
                <Grid ColumnDefinitions="*, Auto, Auto">
                    <Label Text="Geselecteerd Perceel" FontAttributes="Bold" FontSize="18" TextColor="#333333" Grid.Column="0"/>
                    
                    <Button Text="❌ Wis" 
                            Clicked="OnDeselectClicked" 
                            BackgroundColor="Transparent" 
                            TextColor="#666" 
                            FontSize="12"
                            Padding="5"
                            HeightRequest="30"
                            Grid.Column="1"
                            Margin="0,0,10,0"/>

                    <Button Text="✖️ Sluit" 
                            Clicked="OnHidePanelClicked" 
                            BackgroundColor="#F5F5F5" 
                            TextColor="#333" 
                            FontSize="12"
                            Padding="10,0"
                            HeightRequest="30"
                            CornerRadius="15"
                            Grid.Column="2"/>
                </Grid>
                
                <Label x:Name="ParcelIdLabel" Text="Klik op de kaart om een perceel te selecteren" TextColor="#666666" FontSize="14"/>
                <Label x:Name="ParcelSizeLabel" Text="Grootte: --" TextColor="#2B5B2B" FontSize="14" FontAttributes="Bold"/>
                
                <BoxView HeightRequest="1" BackgroundColor="#EEEEEE" Margin="0,5"/>
                
                <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                    <Label Text="Veiligheidscirkel Tonen" VerticalOptions="Center" FontSize="14"/>
                    <Switch x:Name="CircleToggle" Toggled="OnCircleToggleToggled" IsToggled="False"/>
                </HorizontalStackLayout>

                <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                    <Label Text="Wildschade Tonen" VerticalOptions="Center" FontSize="14"/>
                    <Switch x:Name="DamageToggle" Toggled="OnDamageToggleToggled" IsToggled="True"/>
                </HorizontalStackLayout>

                <Button x:Name="ReportDamageButton"
                        Text="⚠️ Meld Wildschade Hier" 
                        Clicked="OnReportDamageClicked"
                        BackgroundColor="#B22222"
                        TextColor="White"
                        CornerRadius="4"
                        HeightRequest="44"
                        FontSize="16"
                        Margin="0,5,0,0"/>

                <Button x:Name="SaveGroundButton" 
                        Text="Opslaan als Jachtveld" 
                        Clicked="OnSaveHuntingGroundClicked"
                        IsVisible="False"
                        BackgroundColor="#2B5B2B"
                        TextColor="White"
                        CornerRadius="4"
                        HeightRequest="44"
                        FontSize="16"/>

                <Label Text="Radius: 300m schietcirkel" FontSize="11" TextColor="#D32F2F" HorizontalOptions="Start"/>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>