<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:FaunaConnect2.App.ViewModels"
             xmlns:models="clr-namespace:FaunaConnect2.App.Models"
             x:Class="FaunaConnect2.App.MainPage"
             x:DataType="viewmodels:MainViewModel"
             Title="FaunaConnect2 - Dashboard">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Logout" Command="{Binding LogoutCommand}" Order="Primary"/>
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20" BackgroundColor="#F5F5F5">
            
            <Label Text="{Binding WelcomeMessage}" 
                   FontSize="26" 
                   FontAttributes="Bold" 
                   TextColor="#2B5B2B"/>

            <!-- Weather & Sun section -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                <Border Grid.Column="0" Padding="15" BackgroundColor="White" Stroke="Transparent">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="2,2" Radius="5" Opacity="0.2"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                        <Label Text="🌬️ Wind" FontSize="14" TextColor="Gray" HorizontalOptions="Center"/>
                        <Label Text="{Binding WindText}" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center"/>
                        <Label Text="{Binding WindDirection}" FontSize="12" TextColor="Gray" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Column="1" Padding="15" BackgroundColor="White" Stroke="Transparent">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="15"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="2,2" Radius="5" Opacity="0.2"/>
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="5" HorizontalOptions="Center">
                        <Label Text="☀️ Sun" FontSize="14" TextColor="Gray" HorizontalOptions="Center"/>
                        <Label Text="{Binding SunriseText}" FontSize="14" HorizontalOptions="Center"/>
                        <Label Text="{Binding SunsetText}" FontSize="14" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10" IsVisible="{Binding IsActionButtonsVisible}">
                <Button Grid.Column="0"
                        Text="New Sighting" 
                        Command="{Binding NewRegistrationCommand}" 
                        BackgroundColor="#2B5B2B" 
                        TextColor="White"
                        CornerRadius="12"
                        HeightRequest="60"
                        FontAttributes="Bold"
                        FontSize="14"/>

                <Button Grid.Column="1"
                        Text="Report Damage" 
                        Command="{Binding ReportDamageCommand}" 
                        BackgroundColor="#B22222" 
                        TextColor="White"
                        CornerRadius="12"
                        HeightRequest="60"
                        FontAttributes="Bold"
                        FontSize="14"/>
            </Grid>

            <Label Text="Recent Sightings" 
                   FontSize="18" 
                   FontAttributes="Bold" 
                   TextColor="#444"
                   Margin="0,10,0,0"/>

            <CollectionView ItemsSource="{Binding RecentRegistrations}" HeightRequest="400">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:Registration">
                        <Border Margin="0,5" Padding="15" BackgroundColor="White" Stroke="Transparent">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="2,2" Radius="5" Opacity="0.1"/>
                            </Border.Shadow>
                            <HorizontalStackLayout Spacing="15">
                                <Label Text="🦌" FontSize="32" VerticalOptions="Center"/>
                                <VerticalStackLayout VerticalOptions="Center">
                                    <Label Text="{Binding AnimalName}" FontAttributes="Bold" FontSize="18" TextColor="#2B5B2B"/>
                                    <Label Text="{Binding DateTime, StringFormat='{0:dd MMM HH:mm}'}" TextColor="DimGray" FontSize="12"/>
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>