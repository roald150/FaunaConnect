<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FaunaConnect2.App.MainPage"
             Title="FaunaConnect2 - Dashboard">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            
            <Label Text="Welkom terug, Jager Roald" 
                   FontSize="24" 
                   FontAttributes="Bold" 
                   TextColor="{StaticResource Primary}"/>

            <Label Text="Actuele wildregistraties in jouw jachtveld:" 
                   FontSize="16" 
                   TextColor="Gray"/>

            <Button Text="Ververs Gegevens" 
                    Clicked="OnRefreshClicked" 
                    BackgroundColor="{StaticResource Primary}" 
                    TextColor="White"
                    CornerRadius="8"/>

            <CollectionView x:Name="RegistrationsListView">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BorderColor="LightGray" CornerRadius="10" Margin="0,5" Padding="15">
                            <VerticalStackLayout Spacing="20">
                                <Label Text="🦌" FontSize="30" VerticalOptions="Center"/>
                                
                                <VerticalStackLayout VerticalOptions="Center">
                                    <Label Text="{Binding AnimalName}" FontAttributes="Bold" FontSize="18"/>
                                    <Label Text="{Binding DateTime, StringFormat='{0:dd-MM-yyyy HH:mm}'}" TextColor="DimGray"/>
                                    <Label Text="{Binding Latitude, StringFormat='GPS: {0}'}" FontSize="12" TextColor="Gray"/>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>